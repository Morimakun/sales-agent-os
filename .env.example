# AIプロバイダ設定
# AI_PROVIDER: openai または anthropic (既定: openai)
AI_PROVIDER=openai

# OpenAI を使う場合
OPENAI_API_KEY=
# Anthropic を使う場合
ANTHROPIC_API_KEY=

# 任意: モデルを上書きする場合 (未指定なら provider ごとの既定モデル)
# 例) openai: gpt-4o-mini / anthropic: claude-haiku-4-5-20251001
AI_MODEL=

# 通信代理店向けLPのURL
# 初回営業文には Dify 直URLではなく、この LP URL を案内する
NEXT_PUBLIC_TELECOM_DEMO_LP_URL=https://telecom-staff-ai-demo.vercel.app/
